# Render PostgreSQL bağlantı URL'si (Render dashboard'dan kopyala)
DATABASE_URL=postgresql://user:password@host/dbname

# Rastgele güçlü bir string — https://djecrety.ir/ üzerinden üretebilirsin
SECRET_KEY=buraya-rastgele-uzun-bir-string-gir

# Gmail ayarları (şifre değil, Gmail "App Password" kullan)
MAIL_USERNAME=inforeviseme@gmail.com
MAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Cloudinary (cloudinary.com/console'dan al)
CLOUDINARY_CLOUD_NAME=senin-cloud-name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
